{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Project",
            "type": "process",
            "isBuildCommand": true,
            "command": "${userHome}/.pico-sdk/ninja/v1.12.1/ninja",
            "args": ["-C", "${workspaceFolder}/build"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc",
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/ninja/v1.12.1/ninja.exe"
            }
        },
        {
            "label": "Run Project",
            "type": "process",
            "command": "${env:HOME}/.pico-sdk/picotool/2.0.0/picotool/picotool",
            "args": [
                "load",
                "${command:raspberry-pi-pico.launchTargetPath}",
                "-fx"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/picotool/2.0.0/picotool/picotool.exe"
            }
        },
        {
            "label": "Flash",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            "args": [
                "-s",
                "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f",
                "interface/cmsis-dap.cfg",
                "-f",
                "target/${command:raspberry-pi-pico.getTarget}.cfg",
                "-c",
                "adapter speed 5000; program \"${command:raspberry-pi-pico.launchTargetPath}\" verify reset exit"
            ],
            "problemMatcher": [],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/openocd/0.12.0+dev/openocd.exe",
            }
        },
        {
            "label": "Build All Configurator ROMs",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "./build", "--target", "configurator_all"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Compile Project"
        },
        {
            "label": "Build TI-99 Configurator",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "./build", "--target", "ti99"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Compile Project"
        },
        {
            "label": "Build ColecoVision Configurator", 
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "./build", "--target", "coleco"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Compile Project"
        },
        {
            "label": "Build MSX Configurator",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "./build", "--target", "msx_asc16"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Compile Project"
        },
        {
            "label": "Configure Combined Firmware",
            "type": "shell",
            "command": "${userHome}/.pico-sdk/cmake/v3.31.5/bin/cmake",
            "args": [
                "-B", "./build-combined",
                "-G", "Ninja",
                "-DPICO9918_BUILD_COMBINED=ON",
                "-DPICO9918_SCART_RGBS=OFF",
                "-DPICO9918_SCART_PAL=OFF",
                "-DPICO9918_NO_SPLASH=OFF",
                "-DPICO9918_DIAG=OFF"
            ],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/cmake/v3.31.5/bin/cmake.exe"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Combined Firmware",
            "type": "shell",
            "command": "${userHome}/.pico-sdk/cmake/v3.31.5/bin/cmake",
            "args": ["--build", "./build-combined"],
            "windows": {
                "command": "${env:USERPROFILE}/.pico-sdk/cmake/v3.31.5/bin/cmake.exe"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Configure Combined Firmware"
        }
    ]
}
